# Copy to .env and adjust paths as needed.

# SQLite database file (optional; default from src/db.py: data/autoname.db under project root)
# DATABASE_PATH=data/autoname.db

# МойСклад API token (do not commit real tokens)
# MOYSKLAD_TOKEN=

# --- NameForge 2.0 / Odoo (see odoo_api_knowledge.md) ---
# DATABASE_URL=sqlite:///./data/autoname.db
# ODOO_URL=https://erp.arszap.ru
# ODOO_DB=stable_arszap
# ODOO_UID=5
# ODOO_API_KEY=
# If ODOO_API_KEY is empty, ODOO_PASSWORD is used as the RPC secret (API key).
# ODOO_USER=
# ODOO_PASSWORD=

# When true (default), Odoo write endpoints simulate changes without HTTP writes.
# DRY_RUN=true
